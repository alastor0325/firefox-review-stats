    },
    maintainAspectRatio: false,
  },
});

// --- Weekly trend, listed members ordered by total review count ---
// Sort descending so the highest-volume reviewer's series is the
// first colour assigned and the first item in the legend.
const allMembers = Object.keys(DATA.weekly_trend.all_members).sort((a, b) => {
  const sumA = DATA.weekly_trend.all_members[a].reduce((s, v) => s + v, 0);
  const sumB = DATA.weekly_trend.all_members[b].reduce((s, v) => s + v, 0);
  return sumB - sumA;
});
new Chart(document.getElementById('chart-trend-all'), {
  type: 'line',
  data: {
    labels: DATA.weekly_trend.weeks,
    datasets: allMembers.map((name, i) => ({
      label: name,
      data: DATA.weekly_trend.all_members[name],
      borderColor: color(i),
      backgroundColor: color(i) + '33',
      tension: 0.25,
      fill: false,
    })),
  },
  options: {
    plugins: { legend: { position: 'bottom' }, tooltip: weeklyTooltip },
    scales: { y: { beginAtZero: true } },
    maintainAspectRatio: false,
  },
});

// =============================================================
// Wait-time section (only if Phabricator data was generated)
// =============================================================
if (PHAB_DATA && PHAB_DATA.n > 0) {
  document.getElementById('phab-section').style.display = 'block';

  // Summary tiles
  const pg = document.getElementById('phab-summary-grid');
  pg.appendChild(stat('Patches with wait data', PHAB_DATA.n, null,
    'Patches we could compute submit→first-review-action latency for (excludes those with no non-author transactions yet).'));
  pg.appendChild(stat('Median wait', PHAB_DATA.percentiles.p50.toFixed(1) + ' d', null,
    '50th percentile: half of patches waited longer than this, half shorter.'));
  pg.appendChild(stat('P75 wait', PHAB_DATA.percentiles.p75.toFixed(1) + ' d', null,
    '75th percentile: a quarter of patches waited longer than this.'));
  pg.appendChild(stat('P90 wait', PHAB_DATA.percentiles.p90.toFixed(1) + ' d', null,
    '90th percentile: a tenth of patches waited longer than this (the "slow tail").'));

  // Histogram
  new Chart(document.getElementById('chart-wait-hist'), {
    type: 'bar',
    data: {
      labels: PHAB_DATA.histogram.map(r => r.bucket),
      datasets: [{
        data: PHAB_DATA.histogram.map(r => r.count),
