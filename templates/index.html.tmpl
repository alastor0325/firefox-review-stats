      }],
    },
    options: {
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: {
          label: ctx => {
            const row = PHAB_DATA.histogram[ctx.dataIndex];
            return `${row.count} (${fmtPct(row.pct)})`;
          },
        }},
      },
      scales: { y: { beginAtZero: true } },
      maintainAspectRatio: false,
    },
