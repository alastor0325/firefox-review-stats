  // Weekly median
  new Chart(document.getElementById('chart-wait-weekly'), {
    type: 'line',
    data: {
      labels: PHAB_DATA.weekly_median.map(r => r.week),
      datasets: [{
        label: 'Median wait (days)',
        data: PHAB_DATA.weekly_median.map(r => r.median_days),
        borderColor: COLOR_NAVY,
        backgroundColor: COLOR_NAVY + '33',
        tension: 0.25,
      }],
    },
    options: {
      plugins: { legend: { position: 'bottom' }, tooltip: weeklyTooltip },
      scales: { y: { beginAtZero: true, title: { display: true, text: 'days' } } },
      maintainAspectRatio: false,
    },
  });

  // --- Most-recent-week slice (team / per-week view) ---
  const lw = PHAB_DATA.last_week;
  if (lw && lw.n > 0) {
    document.getElementById('phab-section-week').style.display = 'block';
    const label = document.getElementById('phab-week-label');
    label.textContent = ` — ${lw.week} (${isoWeekToDateRange(lw.week)})`;

    const wg = document.getElementById('phab-week-summary-grid');
    wg.appendChild(stat('Patches with wait data', lw.n, null,
      'Patches in the most recent ISO week we could compute submit→first-review-action latency for.'));
    wg.appendChild(stat('Median wait', lw.percentiles.p50.toFixed(1) + ' d', null,
      '50th percentile within the most recent week.'));
    wg.appendChild(stat('P75 wait', lw.percentiles.p75.toFixed(1) + ' d', null,
      '75th percentile within the most recent week.'));
    wg.appendChild(stat('P90 wait', lw.percentiles.p90.toFixed(1) + ' d', null,
