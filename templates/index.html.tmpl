      },
    });
  }
}

// =============================================================
// Member Profile view
// =============================================================
(function setupProfileView() {
  const select = document.getElementById('profile-member');
  const ranked = DATA.within_group_total.map(r => r.name);
  const allMembers = Object.keys(DATA.members);
  // Sort: ranked members first by activity, inactive members alphabetically.
  const ordered = [
    ...ranked,
    ...allMembers.filter(m => !ranked.includes(m)).sort(),
  ];
  for (const m of ordered) {
    const opt = document.createElement('option');
    opt.value = m;
    opt.textContent = `${m} (${DATA.members[m] || m})`;
    select.appendChild(opt);
  }

  let weeklyChart = null;
  let authorsChart = null;

  function rolling(values, win) {
    const out = [];
    for (let i = 0; i < values.length; i++) {
      const start = Math.max(0, i - win + 1);
      const slice = values.slice(start, i + 1);
      out.push(slice.reduce((a, b) => a + b, 0) / slice.length);
    }
    return out;
  }

  function fmtWeekRange(weeks, weekly) {
    const firstIdx = weekly.findIndex(c => c > 0);
    const lastIdx  = weekly.findLastIndex ? weekly.findLastIndex(c => c > 0)
                                          : weekly.length - 1 - [...weekly].reverse().findIndex(c => c > 0);
    if (firstIdx < 0) return '—';
    return `${weeks[firstIdx]} → ${weeks[lastIdx]}`;
  }

  function render(member) {
    document.getElementById('profile-name-1').textContent = member;
    document.getElementById('profile-name-2').textContent = member;
    document.getElementById('profile-name-3').textContent = member;

    // Per-member patches-authored count — same source as the Top
    // Authors chart, declared up front so both the summary tile and
    // the wait-time "X of Y" line use the same value.
    const authoredCount = (DATA.member_authored_counts || {})[member] || 0;

    // Per-author wait-time tiles (only if PHAB_DATA is loaded).
    const waitSection = document.getElementById('profile-wait-section');
    const waitGrid = document.getElementById('profile-wait-grid');
    waitGrid.innerHTML = '';
    const pa = (PHAB_DATA && PHAB_DATA.per_author) || {};
    const myWait = pa[member];
    if (myWait && myWait.n_react > 0) {
      waitSection.style.display = '';
      const fmtDays = v => v == null ? '—' : `${v.toFixed(2)} d`;
      // Show the wait-time sample as "X of Y" to make the relationship
      // to "Patches authored" obvious — X is the subset of Y for which
      // we could compute a wait (group added + member reacted on Phab).
      waitGrid.appendChild(stat(
        'Wait-time sample',
        `${myWait.n_react} of ${authoredCount}`,
        'revisions with measurable wait',
        `${myWait.n_react} of ${authoredCount} patches authored by this member had `
        + `both a captured revision-creation timestamp AND at least one reaction `
        + `from a non-author, non-bot reviewer — the subset where wait time is `
        + `measurable. Older revisions whose create event has paged off the Phab `
        + `timeline are not measurable.`
      ));
      waitGrid.appendChild(stat('Time to react (median)', fmtDays(myWait.react_p50), null,
        'Median time from revision creation to the first reaction by any non-author, non-bot reviewer.'));
      waitGrid.appendChild(stat('Time to react (P90)', fmtDays(myWait.react_p90), null,
        '90th percentile — the slow tail.'));
      waitGrid.appendChild(stat('Time to accept (median)', fmtDays(myWait.accept_p50), null,
        'Median time from revision creation to the first accept by any non-author, non-bot reviewer.'));
      waitGrid.appendChild(stat('Time to accept (P90)', fmtDays(myWait.accept_p90), null,
        '90th percentile of time to accept.'));
    } else {
      waitSection.style.display = 'none';
    }

    const total = DATA.total_reviews_per_member.find(r => r.name === member)
                  || { in_group: 0, out_of_group: 0, total: 0 };
    const sole  = DATA.sole_reviewer.find(r => r.name === member)
                  || { count: 0 };
    const rank  = ranked.indexOf(member);
    const weekly = DATA.weekly_trend.all_members[member] || [];
    const authors = (DATA.per_member_authors || {})[member] || [];
    const activeWeeks = weekly.filter(c => c > 0).length;

    const grid = document.getElementById('profile-summary-grid');
    grid.innerHTML = '';
    grid.appendChild(stat('Full name', DATA.members[member] || '—', null,
      'Display name from members.py.'));
    // Patches authored — same source as the Top Authors chart (see
    // the `authoredCount` declaration at the top of this function).
    grid.appendChild(stat('Patches authored', authoredCount, null,
      'Same source / same alias collapse as the 6-Month View "Top patch authors" chart.'));
    grid.appendChild(stat('Total reviews (any tag)', total.total,
      `${total.in_group} in-group · ${total.out_of_group} other`,
      'All in-scope patches this member reviewed in the 6-month window.'));
    grid.appendChild(stat('Sole-reviewer patches', sole.count, null,
      'Patches where this member was the only reviewer named (no group, no co-reviewer).'));
    grid.appendChild(stat('Rank (within-group)',
      rank >= 0 ? `#${rank + 1} of ${ranked.length}` : 'inactive',
      null,
      "This member's position when ranking listed members by group-tagged reviews."));
    grid.appendChild(stat('Active weeks',
      `${activeWeeks} / ${weekly.length}`,
      null,
      'ISO weeks in the window where this member did at least one review.'));
    grid.appendChild(stat('Active period',
      fmtWeekRange(DATA.weekly_trend.weeks, weekly),
      null,
      "First → last ISO week with any review by this member."));

    // Weekly chart: two activity series (reviews / patches submitted)
    // with their 4-week rolling averages overlaid.
    const labels = DATA.weekly_trend.weeks;
    const authoredWeekly =
      (DATA.weekly_trend.authored_per_member || {})[member] || [];
    const datasets = [
      {
        label: 'Reviews / week',
        data: weekly,
        borderColor: COLOR_NAVY,
        backgroundColor: COLOR_NAVY + '22',
        tension: 0.2,
        pointRadius: 2,
        fill: false,
      },
      {
        label: 'Reviews — 4-week avg',
        data: rolling(weekly, 4),
        borderColor: COLOR_NAVY,
        backgroundColor: 'transparent',
        borderDash: [4, 4],
        tension: 0.3,
        pointRadius: 0,
        fill: false,
      },
      {
        label: 'Patches submitted / week',
        data: authoredWeekly,
        borderColor: COLOR_FOREST,
        backgroundColor: COLOR_FOREST + '22',
        tension: 0.2,
        pointRadius: 2,
        fill: false,
      },
      {
        label: 'Submitted — 4-week avg',
        data: rolling(authoredWeekly, 4),
        borderColor: COLOR_FOREST,
        backgroundColor: 'transparent',
        borderDash: [4, 4],
        tension: 0.3,
        pointRadius: 0,
        fill: false,
      },
    ];
    if (weeklyChart) {
      weeklyChart.data.labels = labels;
      weeklyChart.data.datasets = datasets;
      weeklyChart.update();
    } else {
      weeklyChart = new Chart(document.getElementById('chart-profile-weekly'), {
        type: 'line',
        data: { labels, datasets },
        options: {
          plugins: { legend: { position: 'bottom' }, tooltip: weeklyTooltip },
          scales: { y: { beginAtZero: true } },
          maintainAspectRatio: false,
        },
      });
    }

    // Top 15 authors this member reviewed
    const topAuthors = authors.slice(0, 15);
    if (authorsChart) {
      authorsChart.data.labels = topAuthors.map(a => a.name);
      authorsChart.data.datasets[0].data = topAuthors.map(a => a.count);
      authorsChart.update();
    } else {
      authorsChart = new Chart(document.getElementById('chart-profile-authors'), {
        type: 'bar',
        data: {
          labels: topAuthors.map(a => a.name),
          datasets: [{
            data: topAuthors.map(a => a.count),
            backgroundColor: COLOR_FOREST,
          }],
        },
        options: {
          indexAxis: 'y',
          plugins: { legend: { display: false } },
          scales: { x: { beginAtZero: true } },
          maintainAspectRatio: false,
        },
      });
    }

    attachTooltips(document);
  }

  select.addEventListener('change', e => render(e.target.value));
  if (ordered.length > 0) {
    select.value = ordered[0];
    render(ordered[0]);
  }
})();

// =============================================================
// Wait Queue view: per-revision audit table with sortable columns
// =============================================================
(function setupQueue() {
  const rows = (PHAB_DATA && PHAB_DATA.patch_list) || [];
  document.getElementById('queue-total').textContent =
    `${rows.length} revisions`;
  const tbody = document.querySelector('#queue-table tbody');
  const headers = document.querySelectorAll('#queue-table th.sortable');
  if (!tbody) return;

  const fmtDays = v => v == null ? '—' : (
    v < 1 ? `${(v * 24).toFixed(1)} h` : `${v.toFixed(2)} d`
  );
  const escape = s => String(s).replace(/[&<>"']/g, c => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
  })[c]);

  // Render in current sort order. Missing values fall to the bottom.
  function render(sortKey) {
    const sorted = [...rows].sort((a, b) => {
      const av = a[sortKey];
      const bv = b[sortKey];
      if (av == null && bv == null) return 0;
      if (av == null) return 1;
      if (bv == null) return -1;
      return bv - av;
    });
    tbody.innerHTML = '';
    for (const r of sorted) {
      const tr = document.createElement('tr');
      tr.innerHTML = (
        `<td class="num">${fmtDays(r.time_to_react_days)}</td>` +
        `<td class="num">${fmtDays(r.time_to_accept_days)}</td>` +
        `<td class="title"><a href="${escape(r.url)}" target="_blank" rel="noopener">${escape(r.title || r.d_number)}</a></td>` +
        `<td>${escape(r.author || '—')}</td>` +
        `<td>${escape(r.accept_actor || '—')}</td>`
      );
      tbody.appendChild(tr);
    }
    for (const th of headers) {
      th.classList.toggle('active-sort', th.dataset.sort === sortKey);
    }
  }

  for (const th of headers) {
    th.addEventListener('click', () => render(th.dataset.sort));
  }
  render('time_to_accept_days');  // default sort
})();

attachTooltips(document);

// --- Back-to-top button ---
// Visible whenever the #top-sentinel (a 1px div at the top of
// <main>) is out of the viewport — i.e. the user has scrolled
// past it. If the page is short enough that nothing scrolls, the
// sentinel stays in view and the button stays hidden, which
// matches the "only show when scrolling is available" rule.
(function setupBackToTop() {
  const btn = document.getElementById('back-to-top');
  const sentinel = document.getElementById('top-sentinel');
  if (!btn || !sentinel) return;
  const obs = new IntersectionObserver((entries) => {
    for (const e of entries) {
      btn.classList.toggle('is-visible', !e.isIntersecting);
    }
  }, { threshold: 0 });
  obs.observe(sentinel);
  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
})();
</script>

