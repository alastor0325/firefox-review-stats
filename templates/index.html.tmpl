<button type="button" id="back-to-top" aria-label="Back to top" title="Back to top">↑</button>

<script>
const DATA = __DATA_JSON__;
const PHAB_DATA = __PHAB_DATA_JSON__;

const tipEl = document.createElement('div');
tipEl.className = 'tip-floating';
document.body.appendChild(tipEl);

function attachTooltips(root) {
  root.querySelectorAll('.info').forEach(icon => {
    if (icon.dataset.tipBound) return;
    icon.dataset.tipBound = '1';
    icon.addEventListener('mouseenter', () => {
      tipEl.textContent = icon.dataset.tip;
      tipEl.style.display = 'block';
      tipEl.style.left = '0px';
      tipEl.style.top = '0px';
      const tipR = tipEl.getBoundingClientRect();
      const iconR = icon.getBoundingClientRect();
      const margin = 8;
      let top = iconR.bottom + 6;
      if (top + tipR.height > window.innerHeight - margin) {
        top = Math.max(margin, iconR.top - tipR.height - 6);
      }
      let left = iconR.left;
      if (left + tipR.width > window.innerWidth - margin) {
        left = window.innerWidth - tipR.width - margin;
      }
      if (left < margin) left = margin;
      tipEl.style.left = left + 'px';
      tipEl.style.top = top + 'px';
    });
    icon.addEventListener('mouseleave', () => { tipEl.style.display = 'none'; });
  });
}

const fmtPct = v => (v * 100).toFixed(1) + '%';
const fmtNum = v => (typeof v === 'number' && !Number.isInteger(v)) ? v.toFixed(1) : v;

// Editorial palette: Mozilla red lead, with restrained earth + ink tones.
// Chosen for cohesion with the paper-and-ink page aesthetic and for clear
// adjacent-hue contrast in stacked / categorical charts.
const PALETTE = [
  '#FF0039', '#1B3B6F', '#3F5E3F', '#C89B3C', '#7A3B5C',
  '#5B6B7C', '#A4513B', '#8FA47A', '#2D4A87', '#9F7E5E',
  '#5D7B5D', '#B85850', '#446B7F', '#876B49', '#6F4D6F',
];
const color = i => PALETTE[i % PALETTE.length];

// Single-chart accents (referenced below). Kept as named tokens so any
// future tuning of the editorial palette only needs to change one place.
const COLOR_RED   = '#FF0039';  // bus-factor / sole reviewer — high-attention
const COLOR_NAVY  = '#1B3B6F';  // primary data / in-group / wait time
const COLOR_FOREST= '#3F5E3F';  // secondary data / authors / submitted
const COLOR_GRAY  = '#C9C0AE';  // out-of-group / muted backing series

function escAttr(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// Convert an ISO week label like "2026-W20" into the calendar range
// "May 11 – May 17, 2026" so weekly-chart tooltips show real dates.
function isoWeekToDateRange(label) {
  const m = String(label).match(/^(\d{4})-W(\d{2})$/);
  if (!m) return null;
  const year = +m[1], week = +m[2];
  // ISO 8601: week 1 is the week containing January 4th.
  const jan4 = new Date(Date.UTC(year, 0, 4));
  const dayOfWeek = (jan4.getUTCDay() + 6) % 7;  // 0 = Monday
  const week1Monday = new Date(jan4);
  week1Monday.setUTCDate(jan4.getUTCDate() - dayOfWeek);
  const monday = new Date(week1Monday);
  monday.setUTCDate(week1Monday.getUTCDate() + (week - 1) * 7);
  const sunday = new Date(monday);
  sunday.setUTCDate(monday.getUTCDate() + 6);
  const fmt = d => d.toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', timeZone: 'UTC',
  });
  return `${fmt(monday)} – ${fmt(sunday)}, ${sunday.getUTCFullYear()}`;
}

// Tooltip title callback that prepends the calendar range to the ISO
// week label so users can read both "what week is this" and "what
// dates is this" at a glance.
const weeklyTooltip = {
  callbacks: {
    title: (items) => {
      if (!items.length) return '';
      const label = items[0].label;
      const range = isoWeekToDateRange(label);
      return range ? `${label}  ·  ${range}` : label;
    },
  },
};

function stat(label, value, sub, info) {
  const d = document.createElement('div');
  d.className = 'stat';
  const tip = info ? `<span class="info" data-tip="${escAttr(info)}"></span>` : '';
  d.innerHTML = `<div class="label">${label}${tip}</div><div class="value">${value}</div>` + (sub ? `<div class="sub">${sub}</div>` : '');
  return d;
}

function giniOf(values) {
  if (values.length <= 1) return 0;
  const total = values.reduce((a, b) => a + b, 0);
  if (total === 0) return 0;
  const sorted = [...values].sort((a, b) => a - b);
  let weighted = 0;
  sorted.forEach((v, i) => { weighted += (i + 1) * v; });
  return (2 * weighted) / (sorted.length * total) - (sorted.length + 1) / sorted.length;
}

function busFactorOf(values, threshold) {
  if (!values.length) return 0;
  const total = values.reduce((a, b) => a + b, 0);
  if (total === 0) return 0;
  const sorted = [...values].sort((a, b) => b - a);
  let accum = 0;
  for (let i = 0; i < sorted.length; i++) {
    accum += sorted[i];
    if (accum / total >= threshold) return i + 1;
  }
  return sorted.length;
}

function weekStats(weekIndex) {
  const week = DATA.weekly_trend.weeks[weekIndex];
  const counts = {};
  for (const [m, arr] of Object.entries(DATA.weekly_trend.all_members)) {
    counts[m] = arr[weekIndex] || 0;
  }
  const values = Object.values(counts);
  const total = values.reduce((a, b) => a + b, 0);
  const active = values.filter(c => c > 0).length;
  const top = Object.entries(counts).sort((a, b) => b[1] - a[1])[0];
  const topShare = total > 0 ? top[1] / total : 0;
  return {
    week, total, active, top, topShare,
    gini: giniOf(values),
    busFactor: busFactorOf(values, 0.5),
  };
}

// Header
document.getElementById('header-group').textContent = DATA.meta.group;
const excludes = (DATA.meta.excludes || []);
// meta.paths is the multi-root list (one or more roots the team
// owns). meta.path is the legacy singular field, kept for older
// data files; falls back to that when meta.paths is missing.
const watched = (DATA.meta.paths || [DATA.meta.path]).join(', ');
// Title shows the group; the paths live in the meta subtitle so
// the H1 stays readable when a team owns several roots.
document.title = `Reviewer Load — ${DATA.meta.group}`;
const scope = excludes.length
  ? `${watched} (excluding ${excludes.join(', ')})`
  : watched;
const headerMeta = document.getElementById('header-meta');
headerMeta.innerHTML = '';
const scopeLine = document.createElement('div');
scopeLine.textContent = scope;
const timeLine = document.createElement('div');
timeLine.textContent =
  `${DATA.meta.window_start} → ${DATA.meta.window_end} · generated ${DATA.meta.generated_at}`;
headerMeta.appendChild(scopeLine);
headerMeta.appendChild(timeLine);

// Summary grid
const s = DATA.summary;
const sg = document.getElementById('summary-grid');
sg.appendChild(stat('Total in-scope patches', s.total_patches, null,
  `All landings touching ${watched} in the last 6 months` +
  (excludes.length ? `, excluding ${excludes.join(', ')}` : '') +
  ', plus Lando-bot / Revert / merge / code-format commits skipped.'));
sg.appendChild(stat('Tagged with group', s.group_tagged_patches, fmtPct(s.group_tagged_pct) + ' of total',
  `Patches whose r= line includes "${DATA.meta.group}".`));
sg.appendChild(stat('Listed members reviewing', DATA.within_group_total.length, 'of ' + Object.keys(DATA.members).length + ' on the list',
  'How many listed members reviewed at least one patch in the 6-month window.'));
const noTeamTile = stat('Landed without team review', s.landed_without_team_review, fmtPct(s.landed_without_team_review_pct) + ' of total',
  `In-scope patches that landed with neither the ${DATA.meta.group} group tag nor any listed member as a reviewer. A non-zero value means changes in the team's paths are landing without team oversight. Click to see the per-subdirectory breakdown.`);
noTeamTile.classList.add('expandable');
const noTeamHint = document.createElement('div');
noTeamHint.className = 'hint';
noTeamHint.textContent = 'Click to view breakdown';
noTeamTile.appendChild(noTeamHint);
noTeamTile.addEventListener('click', toggleNoTeamReviewSection);
sg.appendChild(noTeamTile);
sg.appendChild(stat('Avg group-tagged / week', fmtNum(s.avg_per_week), null,
  'Group-tagged patches landed per ISO week, averaged across the window.'));

// Concentration grid
const c = DATA.concentration;
const cg = document.getElementById('concentration-grid');
cg.appendChild(stat('Top-1 share', fmtPct(c.top1_share), null,
  'Share of all member-reviews done by the single top member.'));
cg.appendChild(stat('Top-3 share', fmtPct(c.top3_share), null,
  'Share done by the top 3 members combined.'));
cg.appendChild(stat('Top-5 share', fmtPct(c.top5_share), null,
  'Share done by the top 5 members combined.'));
cg.appendChild(stat('Gini coefficient', c.gini.toFixed(2), null,
  'Inequality measure. 0 = perfectly even, 1 = one person does everything. ~0.5+ = significant concentration.'));
cg.appendChild(stat('Bus factor (≥50%)', c.bus_factor, null,
  'Smallest number of members whose absence leaves >50% of reviews uncovered. Lower = more single-point-of-failure risk.'));

// --- Weekly summary + concentration (latest week vs previous) ---
const lastIdx = DATA.weekly_trend.weeks.length - 1;
if (lastIdx >= 0) {
  const now = weekStats(lastIdx);
  const prev = lastIdx > 0 ? weekStats(lastIdx - 1) : null;
  const delta = (curr, base) => {
    if (base == null) return '';
    const d = curr - base;
    if (d === 0) return 'no change vs prev week';
    const sign = d > 0 ? '+' : '';
    return `${sign}${typeof d === 'number' && !Number.isInteger(d) ? d.toFixed(2) : d} vs prev week`;
  };
  const deltaPct = (curr, base) => {
    if (base == null) return '';
    const d = curr - base;
    if (Math.abs(d) < 0.001) return 'no change vs prev week';
    const sign = d > 0 ? '+' : '';
    return `${sign}${fmtPct(d)} vs prev week`;
  };

  document.getElementById('weekly-summary-label').textContent = now.week;
  const wsg = document.getElementById('weekly-summary-grid');
  wsg.appendChild(stat('Group-tagged reviews this week', now.total,
    delta(now.total, prev ? prev.total : null),
    'Reviews by listed members on group-tagged patches in the latest ISO week.'));
  wsg.appendChild(stat('Active members this week', `${now.active} / ${Object.keys(DATA.members).length}`,
    prev ? delta(now.active, prev.active) : '',
    'Listed members with any review activity in the latest week.'));
  wsg.appendChild(stat('Top reviewer this week',
    now.top && now.top[1] > 0 ? `${now.top[0]} (${now.top[1]})` : '—',
    null,
    'Single highest-volume member in the latest week.'));
  wsg.appendChild(stat('Top-1 share this week', fmtPct(now.topShare),
    prev ? deltaPct(now.topShare, prev.topShare) : '',
    'Top member’s share of the week’s member-reviews. Small samples — one review can swing this a lot.'));

  const wcg = document.getElementById('weekly-concentration-grid');
  wcg.appendChild(stat('Top-1 share', fmtPct(now.topShare),
    prev ? deltaPct(now.topShare, prev.topShare) : '',
    'Top member’s share for the latest week.'));
  wcg.appendChild(stat('Gini coefficient', now.gini.toFixed(2),
    prev ? delta(now.gini, prev.gini) : '',
    'Inequality (0 even, 1 one person) for the latest week. Noisy with small weekly samples — watch for sustained drift.'));
  wcg.appendChild(stat('Bus factor (≥50%)', now.busFactor,
    prev ? delta(now.busFactor, prev.busFactor) : '',
    'Bus factor computed over the latest week only.'));
  wcg.appendChild(stat('Active members', `${now.active} / ${Object.keys(DATA.members).length}`,
    prev ? delta(now.active, prev.active) : '',
    'Listed members with any review activity this week.'));
}

// Two-axis toggle wiring: data-view (team|member) × data-period (total|weekly).
// Buttons declare their axis + value via data attributes; one handler per axis.
function bindToggle(axis) {
  const buttons = document.querySelectorAll(`.toggle-bar button[data-${axis}]`);
  function set(value) {
    document.body.dataset[axis] = value;
    for (const b of buttons) {
      b.classList.toggle('active', b.dataset[axis] === value);
    }
  }
  for (const b of buttons) {
    b.addEventListener('click', () => set(b.dataset[axis]));
  }
}
bindToggle('view');
bindToggle('period');

function horizontalBar(canvasId, rows, fill) {
  const colors = (typeof fill === 'function')
    ? rows.map((_, i) => fill(i))
    : rows.map(() => fill);
  return new Chart(document.getElementById(canvasId), {
    type: 'bar',
    data: {
      labels: rows.map(r => r.name),
      datasets: [{
        data: rows.map(r => r.count),
        backgroundColor: colors,
      }],
    },
    options: {
      indexAxis: 'y',
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: {
          label: ctx => {
            const row = rows[ctx.dataIndex];
            return row.pct != null
              ? `${row.count} (${fmtPct(row.pct)})`
              : `${row.count}`;
          },
        }},
      },
      scales: { x: { beginAtZero: true } },
      maintainAspectRatio: false,
    },
  });
}

horizontalBar('chart-distribution', DATA.within_group_total, color);
horizontalBar('chart-sole',         DATA.sole_reviewer,       COLOR_RED);
horizontalBar('chart-authors',      DATA.authors.top_total,   COLOR_FOREST);

// --- Total reviews per member (stacked: in-group vs out-of-group) ---
new Chart(document.getElementById('chart-total-reviews'), {
  type: 'bar',
  data: {
    labels: DATA.total_reviews_per_member.map(r => r.name),
    datasets: [
      {
        label: `${DATA.meta.group}-tagged`,
        data: DATA.total_reviews_per_member.map(r => r.in_group),
        backgroundColor: COLOR_NAVY,
      },
      {
        label: 'other in-scope',
        data: DATA.total_reviews_per_member.map(r => r.out_of_group),
        backgroundColor: COLOR_GRAY,
      },
    ],
  },
  options: {
    indexAxis: 'y',
    plugins: {
      legend: { position: 'bottom' },
      tooltip: {
        mode: 'index',
        callbacks: {
          footer: items => {
            const row = DATA.total_reviews_per_member[items[0].dataIndex];
            return `Total: ${row.total}`;
          },
        },
      },
    },
    scales: {
      x: { stacked: true, beginAtZero: true },
      y: { stacked: true },
    },
    maintainAspectRatio: false,
  },
});

// --- Within-group distribution (doughnut) ---
new Chart(document.getElementById('chart-distribution-pie'), {
  type: 'doughnut',
  data: {
    labels: DATA.within_group_total.map(r => r.name),
    datasets: [{
      data: DATA.within_group_total.map(r => r.count),
      backgroundColor: DATA.within_group_total.map((_, i) => color(i)),
      borderWidth: 1,
    }],
  },
  options: {
    plugins: {
      legend: { position: 'bottom', labels: { boxWidth: 12 } },
      tooltip: { callbacks: {
        label: ctx => `${ctx.label}: ${ctx.parsed} (${fmtPct(DATA.within_group_total[ctx.dataIndex].pct)})`,
      }},
    },
    maintainAspectRatio: false,
  },
});

// --- Landed without team review: pie + full patch list ---
// Both hidden behind a click on the corresponding summary tile so
// the Team view stays focused on headline metrics. Pie + table are
// each rendered on first reveal of their containers.
const noTeamReviewList = s.landed_without_team_review_list || [];
document.getElementById('no-team-review-list-count').textContent = noTeamReviewList.length;

let noTeamReviewTableBuilt = false;
function buildNoTeamReviewTable() {
  if (noTeamReviewTableBuilt) return;
  noTeamReviewTableBuilt = true;
  const container = document.getElementById('no-team-review-list-container');
  if (!noTeamReviewList.length) {
    container.innerHTML = '<div class="footer-note">No patches to list.</div>';
    return;
  }
  const t = document.createElement('table');
  const headers = ['Date', 'Subdir', 'Patch', 'Author', 'Reviewers'];
  t.innerHTML = '<thead><tr>' + headers.map(h => `<th>${h}</th>`).join('') + '</tr></thead>';
  const tbody = document.createElement('tbody');
  for (const row of noTeamReviewList) {
    const phabUrl = row.differential_revision
      ? `https://phabricator.services.mozilla.com/${escAttr(row.differential_revision)}`
      : null;
    const subjectCell = phabUrl
      ? `<a href="${phabUrl}" target="_blank" rel="noopener">${escHtml(row.subject)}</a>`
      : escHtml(row.subject);
    const reviewers = row.reviewers
      .map(r => r.name + (r.is_group ? ' (group)' : ''))
      .join(', ') || '(none)';
    const tr = document.createElement('tr');
    tr.innerHTML = (
      `<td>${escHtml(row.date)}</td>` +
      `<td class="subdir-cell">${escHtml(row.primary_subdir)}</td>` +
      `<td class="subject">${subjectCell}</td>` +
      `<td>${escHtml(row.author)}</td>` +
      `<td>${escHtml(reviewers)}</td>`
    );
    tbody.appendChild(tr);
  }
  t.appendChild(tbody);
  container.appendChild(t);
}
document.getElementById('no-team-review-list-details').addEventListener('toggle', (e) => {
  if (e.target.open) buildNoTeamReviewTable();
});

let noTeamReviewChart = null;
function setNoTeamReviewOpen(open) {
  const section = document.getElementById('landed-without-review-section');
  section.style.display = open ? 'block' : 'none';
  noTeamTile.classList.toggle('is-open', open);
  noTeamHint.textContent = open ? 'Click to hide' : 'Click to view breakdown';
}
document.getElementById('close-no-team-review').addEventListener('click', (e) => {
  e.stopPropagation();
  setNoTeamReviewOpen(false);
});
function toggleNoTeamReviewSection() {
  const section = document.getElementById('landed-without-review-section');
  const ntrBySubdir = s.landed_without_team_review_by_subdir || {};
  const ntrEntries = Object.entries(ntrBySubdir).sort((a, b) => b[1] - a[1]);
  if (ntrEntries.length === 0) {
    return;  // nothing to show
  }
  const open = section.style.display !== 'none' && section.style.display !== '';
  if (open) {
    setNoTeamReviewOpen(false);
    return;
  }
  setNoTeamReviewOpen(true);
  if (noTeamReviewChart) return;  // already rendered
  const ntrTotal = ntrEntries.reduce((sum, [, n]) => sum + n, 0) || 1;
  const ntrLabels = ntrEntries.map(([k]) => k);
  const ntrCounts = ntrEntries.map(([, n]) => n);
  noTeamReviewChart = new Chart(document.getElementById('chart-no-team-review'), {
    type: 'doughnut',
    data: {
      labels: ntrLabels,
      datasets: [{
        data: ntrCounts,
        backgroundColor: ntrLabels.map((_, i) => color(i)),
        borderWidth: 1,
      }],
    },
    options: {
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 12 } },
        tooltip: { callbacks: {
          label: ctx => `${ctx.label}: ${ctx.parsed} (${fmtPct(ctx.parsed / ntrTotal)})`,
        }},
      },
      maintainAspectRatio: false,
    },
  });
}

// --- Author → reviewer matrix (stacked bar) ---
const matrix = DATA.authors.reviewer_matrix;
const matrixAuthors = Object.keys(matrix);
const memberIds = Object.keys(DATA.members);
new Chart(document.getElementById('chart-author-reviewer'), {
  type: 'bar',
  data: {
    labels: matrixAuthors,
    datasets: memberIds.map((m, i) => ({
      label: m,
      data: matrixAuthors.map(a => (matrix[a] || {})[m] || 0),
